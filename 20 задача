
class Node:
    def __init__(self, value, left=None, right=None):
        self.value = value
        self.left = left
        self.right = right

    def is_operator(self):
        return self.value in ('+', '-', '*', '/', 'u-')

    def is_unary_minus(self):
        return self.value == 'u-'

    def is_number(self):
        try:
            float(self.value)
            return True
        except (ValueError, TypeError):
            return False

    def is_variable(self):
        return isinstance(self.value, str) and len(self.value) == 1 and self.value.isalpha()

    def __str__(self):
        if self.is_unary_minus():
            left_str = str(self.left)
            if self.left and self.left.is_operator() and self._precedence(self.left.value) < self._precedence(self.value):
                left_str = f"({left_str})"
            return f"-{left_str}"
        if not self.is_operator():
            return str(self.value)

        left_str = str(self.left)
        right_str = str(self.right)

        if self.left and self.left.is_operator() and self._precedence(self.left.value) < self._precedence(self.value):
            left_str = f"({left_str})"
        if self.right and self.right.is_operator() and self._precedence(self.right.value) <= self._precedence(self.value):
            right_str = f"({right_str})"

        return f"{left_str}{self.value}{right_str}"

    @staticmethod
    def _precedence(op):
        if op in ('+', '-'):
            return 1
        if op in ('*', '/'):
            return 2
        return 0


class ExpressionParser:
    def __init__(self, expression):
        self.expression = expression.replace(' ', '')

    def tokenize(self):
        tokens = []
        i = 0
        while i < len(self.expression):
            ch = self.expression[i]

            if ch.isdigit():
                num = ''
                while i < len(self.expression) and self.expression[i].isdigit():
                    num += self.expression[i]
                    i += 1
                tokens.append(num)
                continue

            elif ch.isalpha():
                tokens.append(ch)
                i += 1
                continue

            elif ch in '+-*/()':
                tokens.append(ch)
                i += 1
                continue

            else:
                raise ValueError(f"Недопустимый символ: '{ch}'")

        processed = []
        for i, token in enumerate(tokens):
            if token == '-' and (i == 0 or tokens[i-1] in '+-*/('):
                processed.append('u-')
            else:
                processed.append(token)

        return processed

    def infix_to_postfix(self, tokens):
        output = []
        stack = []
        precedence = {'+': 1, '-': 1, '*': 2, '/': 2, 'u-': 3}

        for token in tokens:
            if token.isdigit() or token.isalpha():
                output.append(token)
            elif token == 'u-':
                stack.append(token)
            elif token == '(':
                stack.append(token)
            elif token == ')':
                while stack and stack[-1] != '(':
                    output.append(stack.pop())
                if stack and stack[-1] == '(':
                    stack.pop()
                else:
                    raise ValueError("Непарная закрывающая скобка")
            else:
                while (stack and stack[-1] != '(' and
                       precedence.get(stack[-1], 0) >= precedence.get(token, 0)):
                    output.append(stack.pop())
                stack.append(token)

        while stack:
            if stack[-1] == '(':
                raise ValueError("Непарная открывающая скобка")
            output.append(stack.pop())

        return output

    def build_tree(self):
        tokens = self.tokenize()
        postfix = self.infix_to_postfix(tokens)
        return self._build_from_postfix(postfix)

    def _build_from_postfix(self, postfix):
        stack = []

        for token in postfix:
            if token.isdigit():
                stack.append(Node(int(token)))
            elif token.isalpha():
                stack.append(Node(token))
            elif token == 'u-':
                if not stack:
                    raise ValueError("Некорректный унарный минус")
                operand = stack.pop()
                stack.append(Node('u-', operand))
            else:
                if len(stack) < 2:
                    raise ValueError(f"Недостаточно операндов для оператора '{token}'")
                right = stack.pop()
                left = stack.pop()
                stack.append(Node(token, left, right))

        if len(stack) != 1:
            raise ValueError("Некорректное выражение")

        return stack[0] if stack else None


def validate_formula(expression: str) -> bool:
    if not expression or expression.strip() == "":
        return False

    expr = expression.replace(' ', '')

    allowed = set('0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ+-*/()')
    for ch in expr:
        if ch not in allowed:
            return False

    balance = 0
    for ch in expr:
        if ch == '(':
            balance += 1
        elif ch == ')':
            balance -= 1
            if balance < 0:
                return False
    if balance != 0:
        return False

    for i in range(len(expr) - 1):
        if expr[i] == '(' and expr[i+1] == ')':
            return False
        if expr[i].isdigit() and expr[i+1].isalpha():
            return False
        if expr[i].isalpha() and expr[i+1].isdigit():
            return False
        if expr[i].isalpha() and expr[i+1].isalpha():
            return False

    ops = set('+-*/')
    for i, ch in enumerate(expr):
        if ch in ops:
            if i == 0 and ch != '-':
                return False
            if i == len(expr) - 1:
                return False
            if i > 0 and expr[i-1] in ops:
                if not (ch == '-' and expr[i-1] in ops):
                    return False
            if i > 0:
                prev = expr[i-1]
                if not (prev.isdigit() or prev.isalpha() or prev == ')' or prev == '('):
                    if not (ch == '-' and prev in ops):
                        return False
            if i < len(expr) - 1:
                next_ch = expr[i+1]
                if not (next_ch.isdigit() or next_ch.isalpha() or next_ch == '('):
                    if ch == '-' and next_ch.isdigit():
                        pass
                    else:
                        return False

    return True


class ExpressionSimplifier:
    @staticmethod
    def simplify(node):
        if node is None:
            return None

        if node.left:
            node.left = ExpressionSimplifier.simplify(node.left)
        if node.right:
            node.right = ExpressionSimplifier.simplify(node.right)

        if node.is_operator() and node.value in ('+', '-', '*', '/'):
            if node.left and node.left.is_number() and node.right and node.right.is_number():
                calc = ExpressionCalculator()
                result = calc.evaluate(node)
                return Node(int(result) if result.is_integer() else result)

        if node.is_operator():
            simplified = ExpressionSimplifier._apply_rules(node)
            if simplified:
                return simplified

        return node

    @staticmethod
    def _apply_rules(node):
        if node.value == '+':
            if node.left and node.left.is_unary_minus() and node.right and node.right.is_number():
                return Node('-', node.right, node.left.left)
            if node.right and node.right.is_unary_minus() and node.left and node.left.is_number():
                return Node('-', node.left, node.right.left)
            if node.left and node.left.is_unary_minus() and node.right and node.right.is_unary_minus():
                inner = Node('+', node.left.left, node.right.left)
                return Node('u-', inner)

        if node.value == '-':
            if node.left and node.left.is_unary_minus() and node.right and node.right.is_number():
                inner = Node('+', node.left.left, node.right)
                return Node('u-', inner)
            if node.right and node.right.is_unary_minus() and node.left and node.left.is_number():
                return Node('+', node.left, node.right.left)
            if node.left and node.left.is_unary_minus() and node.right and node.right.is_unary_minus():
                return Node('-', node.right.left, node.left.left)

        if node.value not in ('+', '-'):
            return None

        result = ExpressionSimplifier._rule_common_right(node)
        if result:
            return result

        result = ExpressionSimplifier._rule_common_left(node)
        if result:
            return result

        return None

    @staticmethod
    def _is_same(node1, node2):
        if node1 is None and node2 is None:
            return True
        if node1 is None or node2 is None:
            return False
        if node1.value != node2.value:
            return False
        return (ExpressionSimplifier._is_same(node1.left, node2.left) and
                ExpressionSimplifier._is_same(node1.right, node2.right))

    @staticmethod
    def _rule_common_right(node):
        if node.value not in ('+', '-'):
            return None

        left = node.left
        right = node.right

        if not left or not right or left.value != '*' or right.value != '*':
            return None

        matches = []
        if ExpressionSimplifier._is_same(left.right, right.right):
            matches.append((left.left, right.left, left.right))
        if ExpressionSimplifier._is_same(left.right, right.left):
            matches.append((left.left, right.right, left.right))
        if ExpressionSimplifier._is_same(left.left, right.right):
            matches.append((left.right, right.left, left.left))
        if ExpressionSimplifier._is_same(left.left, right.left):
            matches.append((left.right, right.right, left.left))

        if matches:
            f1, f2, f3 = matches[0]
            new_inner = Node(node.value, f1, f2)
            return Node('*', new_inner, f3)

        return None

    @staticmethod
    def _rule_common_left(node):
        if node.value not in ('+', '-'):
            return None

        left = node.left
        right = node.right

        if not left or not right or left.value != '*' or right.value != '*':
            return None

        matches = []
        if ExpressionSimplifier._is_same(left.left, right.left):
            matches.append((left.left, left.right, right.right))
        if ExpressionSimplifier._is_same(left.left, right.right):
            matches.append((left.left, left.right, right.left))
        if ExpressionSimplifier._is_same(left.right, right.left):
            matches.append((left.right, left.left, right.right))
        if ExpressionSimplifier._is_same(left.right, right.right):
            matches.append((left.right, left.left, right.left))

        if matches:
            f1, f2, f3 = matches[0]
            new_inner = Node(node.value, f2, f3)
            return Node('*', f1, new_inner)

        return None


class ExpressionCalculator:
    def __init__(self, variables=None):
        self.variables = variables or {}

    def evaluate(self, node):
        if node is None:
            return 0

        if node.is_number():
            return float(node.value)

        if node.is_variable():
            if node.value in self.variables:
                return self.variables[node.value]
            raise ValueError(f"Переменная '{node.value}' не определена")

        if node.is_unary_minus():
            return -self.evaluate(node.left)

        if node.value == '+':
            return self.evaluate(node.left) + self.evaluate(node.right)
        elif node.value == '-':
            return self.evaluate(node.left) - self.evaluate(node.right)
        elif node.value == '*':
            return self.evaluate(node.left) * self.evaluate(node.right)
        elif node.value == '/':
            right_val = self.evaluate(node.right)
            if right_val == 0:
                raise ZeroDivisionError("Деление на ноль!")
            return self.evaluate(node.left) / right_val

        raise ValueError(f"Неизвестный оператор: {node.value}")


def run_tests():
    print("\n" + "=" * 70)
    print("  🧪 ТЕСТИРОВАНИЕ ЗАДАЧИ №20")
    print("=" * 70)

    test_cases = [
        ("a*b + a*c", "a*(b+c)", "Общий множитель слева (+)"),
        ("a*b - a*c", "a*(b-c)", "Общий множитель слева (-)"),
        ("a*c + b*c", "(a+b)*c", "Общий множитель справа (+)"),
        ("a*c - b*c", "(a-b)*c", "Общий множитель справа (-)"),
        ("2*x + 3*x", "(2+3)*x", "Упрощение с числами (+)"),
        ("5*y - 2*y", "(5-2)*y", "Упрощение с числами (-)"),
        ("x*y + x*z - x*w", "x*(y+z-w)", "Сложное упрощение"),
        ("(a+b)*c + (a+b)*d", "(a+b)*(c+d)", "Сложный множитель"),
        ("a*b + c*a", "a*(b+c)", "Коммутативность (a*b + c*a)"),
        ("b*a + a*c", "a*(b+c)", "Коммутативность (b*a + a*c)"),
        ("a*b + c*b", "(a+c)*b", "Коммутативность (a*b + c*b)"),
        ("-x + 3", "3-x", "Унарный минус (перестановка)"),
        ("3 + (-x)", "3-x", "Унарный минус (3 + (-x))"),
        ("-x + (-y)", "-(x+y)", "Унарный минус (сумма)"),
        ("-(-x)", "x", "Двойной унарный минус"),
        ("-5 + 3", "-2", "Унарный минус с числом"),
        ("2*3 + 4", "10", "Вычисление 1"),
        ("(2+3)*(4+5)", "45", "Вычисление 2"),
    ]

    passed = 0
    for expr, expected, desc in test_cases:
        try:
            parser = ExpressionParser(expr)
            tree = parser.build_tree()

            if expected.replace(" ", "").replace("-", "").isdigit():
                calc = ExpressionCalculator()
                result = calc.evaluate(tree)
                result_str = str(int(result)) if result.is_integer() else str(result)
                passed_test = (result_str == expected)
            else:
                simplifier = ExpressionSimplifier()
                simplified = simplifier.simplify(tree)
                result_str = str(simplified) if simplified else ""
                passed_test = (expected.replace(" ", "") == result_str.replace(" ", ""))

            status = "✅" if passed_test else "❌"
            if passed_test:
                passed += 1

            print(f"\n{status} {desc}")
            print(f"   Исходное: {expr}")
            print(f"   Получено: {result_str}")
            print(f"   Ожидалось: {expected}")

        except Exception as e:
            print(f"\n❌ Ошибка в тесте '{expr}': {e}")

    print("\n" + "-" * 70)
    print("  🛡️ ТЕСТЫ НА НЕКОРРЕКТНЫЙ ВВОД")
    print("-" * 70)

    error_tests = [
        ("", "пустая строка"),
        ("a*b + @", "недопустимый символ (@)"),
        ("(a+b", "непарная скобка (открывающая)"),
        ("a+b)", "непарная скобка (закрывающая)"),
        ("a++b", "операторы подряд (++)"),
        ("a+b-", "оператор в конце"),
        ("()", "пустые скобки"),
        ("2x", "число+буква (2x)"),
        ("ab", "буква+буква (ab)"),
        ("a2", "буква+число (a2)"),
    ]

    passed_errors = 0
    for expr, desc in error_tests:
        try:
            parser = ExpressionParser(expr)
            tree = parser.build_tree()
            print(f"❌ {desc}: '{expr}' → ДОЛЖНА БЫТЬ ОШИБКА, но прошло")
        except Exception as e:
            print(f"✅ {desc}: '{expr}' → Ошибка перехвачена")
            passed_errors += 1

    print("\n" + "=" * 70)
    print(f"📊 КОРРЕКТНЫЕ ТЕСТЫ: {passed}/{len(test_cases)} пройдено")
    print(f"📊 ТЕСТЫ НА ОШИБКИ: {passed_errors}/{len(error_tests)} пройдено")
    print(f"📊 ВСЕГО: {passed + passed_errors}/{len(test_cases) + len(error_tests)} пройдено")
    print("=" * 70)


